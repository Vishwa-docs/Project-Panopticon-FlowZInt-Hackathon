# Optional provider credentials. The local deterministic engine runs without these.
FLOWZINT_API_KEY=
FLOWZINT_BASE_URL=https://api.flowzint.example/v1
FLOWZINT_FAST_MODEL=llama-3.1-8b-instruct
FLOWZINT_GUARD_MODEL=gpt-4o

# Optional hosted memory. The app uses a file/in-memory store when absent.
REDIS_URL=

# Runtime tuning
PANOPTICON_CACHE_TTL_SECONDS=3600
